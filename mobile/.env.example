# Variables de entorno de la app (se pasan en compilación con --dart-define).
# Copia a .env para tu referencia; NO se lee en runtime (Flutter usa --dart-define).
#
# Ejemplo de build apuntando a un backend distinto:
#   flutter build apk --dart-define=API_BASE_URL=https://mi-backend/api
#
# Producción (valor por defecto si no se pasa nada):
API_BASE_URL=https://flotadsp-backend.fly.dev/api
